# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Keep-warm self-ping (defeats Render free-tier cold starts). In production set
# this to the backend's PUBLIC url, e.g. https://your-api.onrender.com
# Render also injects RENDER_EXTERNAL_URL automatically, which is used as a fallback.
SELF_PING_URL=

# ============================================
# DATABASE (SUPABASE)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
BCRYPT_SALT_ROUNDS=10
PROFILE_OWNER_ID=your-profile-owner-uuid

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:4200

# ============================================
# CORS ORIGINS (comma-separated)
# ============================================
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ============================================
# AI PROVIDER (For AI Chat + post-writing assist)
# ============================================
# Default provider is OpenAI (gpt-4o-mini). To use a free OpenAI-compatible
# provider instead — e.g. NVIDIA NIM (build.nvidia.com) — set all three below.
#   AI_BASE_URL=https://integrate.api.nvidia.com/v1
#   AI_API_KEY=<your nvidia api key>
#   AI_MODEL=meta/llama-3.3-70b-instruct   # or meta/llama-3.1-8b-instruct (faster)
OPENAI_API_KEY=your-openai-api-key-here
# AI_BASE_URL=
# AI_API_KEY=
# AI_MODEL=

# ============================================
# EMAIL SERVICE (Optional - for password reset)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourapp.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# CONTACT EMAIL
# ============================================
CONTACT_EMAIL=support@yourapp.com

# ============================================
# ASSET STORAGE (Supabase Storage)
# ============================================
ASSET_BUCKET=assets
# Supabase storage bucket for profile images and resume (default: assets)
RESUME_SIGNED_URL_EXPIRY=600
# Resume signed URL validity in seconds (default: 600 = 10 min)

# ============================================
# SMS NOTIFICATIONS (Optional)
# ============================================
ENABLE_SMS=false
# Set to "true" to receive SMS on new contact form submissions
FAST2SMS_API_KEY=your-fast2sms-api-key
# Required only when ENABLE_SMS=true
MY_MOBILE_NUMBER=9XXXXXXXXX
# 10-digit mobile number to receive alerts — required only when ENABLE_SMS=true
